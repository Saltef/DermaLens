# DermaLens runtime configuration

APP_HOST=0.0.0.0
APP_PORT=8080
SAVE_UPLOADS=false

# Offline/privacy defaults
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_DATASETS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
WANDB_DISABLED=true
DO_NOT_TRACK=1

# Optional model prior calibration
PRIOR_PROFILE=conservative_population_like
PRIOR_ALPHA=0.4
PRIOR_PROFILE_PATH=/app/models/prior_profiles.json
TRAINING_PRIOR_PATH=/app/models/training_prior_combined.json
